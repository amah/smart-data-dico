{
  "name": "@hamak/smart-data-dico-desktop",
  "productName": "Smart Data Dictionary",
  "version": "0.0.0",
  "private": true,
  "description": "Electron desktop shell for Smart Data Dictionary (issue #206)",
  "author": "hamak",
  "homepage": "https://github.com/amah/smart-data-dico",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && electron .",
    "electron": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "install:mac": "node scripts/install-mac.mjs",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.0"
  }
}
