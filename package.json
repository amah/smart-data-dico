{
  "name": "@hamak/smart-data-dico",
  "version": "1.15.0",
  "description": "Collaborative data dictionary management system \u2014 model, document, and govern your data landscape",
  "type": "module",
  "bin": {
    "smart-data-dico": "bin/cli.js"
  },
  "scripts": {
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "node scripts/build-backend.mjs",
    "start": "node bin/cli.js",
    "install:skill": "bash scripts/install-skill.sh",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "bin/",
    "backend/dist/",
    "frontend/dist/",
    "data-dictionaries/stereotypes.yaml"
  ],
  "keywords": [
    "data-dictionary",
    "data-modeling",
    "data-governance",
    "schema-management",
    "yaml",
    "git"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amah/smart-data-dico.git"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai": "^3.0.49",
    "@hamak/filesystem-server-api": "^0.5.2",
    "@hamak/filesystem-server-impl": "^0.5.2",
    "@hamak/filesystem-server-spi": "^0.5.2",
    "@hamak/shared-utils": "^0.5.2",
    "@hamak/ui-remote-git-fs-backend": "^0.5.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.17.50",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ai": "^6.0.143",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "esbuild": "^0.27.4",
    "express": "^4.18.2",
    "jsonschema": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.0.0",
    "yaml": "^2.3.1",
    "zod": "^4.3.6"
